{
  "rewrites": [
    { "source": "/friend/:handle", "destination": "/friend.html" },
    { "source": "/(.*)", "destination": "/chalk/$1", "has": [{ "type": "host", "value": "chalk.tsaur.com" }] }
  ],
  "headers": [
    {
      "source": "/.well-known/apple-app-site-association",
      "headers": [
        { "key": "Content-Type", "value": "application/json" }
      ]
    }
  ]
}
