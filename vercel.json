{
  "rewrites": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "chalk.tsaur.com" }],
      "destination": "/chalk/:path*"
    },
    { "source": "/friend/:handle", "destination": "/friend.html" }
  ],
  "headers": [
    {
      "source": "/.well-known/apple-app-site-association",
      "headers": [
        { "key": "Content-Type", "value": "application/json" }
      ]
    }
  ]
}
